# Local development defaults
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=financially_fit
DB_PORT=5433
BACKEND_PORT=18000
FRONTEND_PORT=13000

# Local mode uses app-issued JWTs
AUTH_MODE=jwt
ALLOWED_ORIGINS=http://localhost:13000
REACT_APP_API_URL=http://localhost:18000

